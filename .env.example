APP_NAME="PHPolygon Editor"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost

# ─── NativePHP ────────────────────────────────────────────────────────────────
NATIVEPHP_APP_ID=com.phpolygon.editor
NATIVEPHP_APP_VERSION=1.0.0
NATIVEPHP_APP_AUTHOR="Your Name"
NATIVEPHP_APP_COPYRIGHT="© 2026 Your Name"
NATIVEPHP_APP_DESCRIPTION="PHPolygon Game Engine Editor"
NATIVEPHP_APP_WEBSITE=https://github.com/phpolygon/phpolygon
NATIVEPHP_DEEPLINK_SCHEME=phpolygon-editor

# Auto-Updater (false = disabled during development)
NATIVEPHP_UPDATER_ENABLED=false
NATIVEPHP_UPDATER_PROVIDER=github

# GitHub Updater — nur nötig wenn NATIVEPHP_UPDATER_ENABLED=true
GITHUB_REPO=phpolygon
GITHUB_OWNER=phpolygon
GITHUB_TOKEN=
# ──────────────────────────────────────────────────────────────────────────────

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
